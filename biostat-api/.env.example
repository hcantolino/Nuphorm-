# ─────────────────────────────────────────────────────────────────────────────
# NuPhorm Biostatistics API — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── CDISC Library API ──────────────────────────────────────────────────────────
# Register for a free key at: https://api.developer.library.cdisc.org
# Without a key the API falls back to hard-coded ADaMIG 1.3 metadata and
# NCI CT values; all endpoints remain functional.
CDISC_API_KEY=

# Base URL for the CDISC Library REST API (change only if using a mirror/proxy)
CDISC_LIBRARY_BASE_URL=https://library.cdisc.org/api


# ── ADaM defaults ─────────────────────────────────────────────────────────────
# ADaMIG version applied when the request body omits adam_version
DEFAULT_ADAM_VERSION=1.3

# CDISC Dataset-JSON version tag embedded in every export
DATASET_JSON_VERSION=1.0.0

# Free-text originator string written to Define-XML / Dataset-JSON headers
ORIGINATOR=NuPhorm Platform


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use "*" for development; restrict to your frontend URL in production.
#   CORS_ORIGINS=https://app.nuphorm.com,https://staging.nuphorm.com
CORS_ORIGINS=*


# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
